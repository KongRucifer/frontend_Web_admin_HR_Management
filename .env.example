# ===== Web admin (Vite) =====
# Copy to ".env" and adjust. Client-exposed vars must start with VITE_.

# Dev-server port (vite dev).
VITE_DEV_PORT=5173

# Base path the app's axios client calls. Keep as a same-origin path so the
# httpOnly auth cookie stays first-party; Vite proxies it to the backend.
VITE_API_BASE_URL=/api

# Where the "/api" dev proxy forwards requests (the NestJS backend origin).
# DEV ONLY — used by vite. The production door (server.mjs) uses BACKEND_ORIGIN.
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# ===== Production door (server.mjs — `pnpm start`) =====
# These are read at RUNTIME by server.mjs, not baked into the build, so the same
# dist/ works on any host. VITE_* above are irrelevant once built — VITE_API_BASE_URL
# stays "/api" (baked in) and the door proxies it.
#
# PORT           — the public port this server listens on (the URL's port).
# BACKEND_ORIGIN — where the backend actually listens (private, localhost).
PORT=8086
BACKEND_ORIGIN=http://127.0.0.1:3000
