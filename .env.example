# ===== Web admin (Vite) =====
# Copy to ".env" and adjust. Client-exposed vars must start with VITE_.

# Dev-server port (vite dev).
VITE_DEV_PORT=5173

# Base path the app's axios client calls. Keep as a same-origin path so the
# httpOnly auth cookie stays first-party; Vite proxies it to the backend.
VITE_API_BASE_URL=/api

# Where the "/api" dev proxy forwards requests (the NestJS backend origin).
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
